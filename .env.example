VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ─── SERVICE ROLE KEY (required for admin user management) ──────────────────
# Find this in: Supabase Dashboard → Settings → API → service_role
# Also add this variable in: Vercel → Project Settings → Environment Variables
# ⚠️ KEEP THIS SECRET — never commit to public repos
VITE_SUPABASE_SERVICE_KEY=your_service_role_key_here


